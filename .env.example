# Copy this to .env and fill in real values
# Never commit .env to git

# Database
DB_PASSWORD=quill_dev

# App
SECRET_KEY=change-this-to-a-random-string-in-production

# URLs — change these for production (use your real domain, no trailing slash)
# Dev:  http://127.0.0.1:8001 / http://127.0.0.1:5174
# Prod: https://yourdomain.com / https://yourdomain.com
FRONTEND_URL=http://127.0.0.1:5174
CLIO_REDIRECT_URI=https://127.0.0.1/api/auth/clio/callback

# Clio OAuth (from your Clio developer app)
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=

# AI Providers (fill in what you have)
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
